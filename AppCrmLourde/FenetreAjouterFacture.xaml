<Window x:Class="AppCrmLourde.FenetreAjouterFacture"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Ajouter Facture" Height="320" Width="400"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="120"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Labels -->
        <Label Grid.Row="0" Grid.Column="0" Content="Client:" Margin="5"/>
        <Label Grid.Row="1" Grid.Column="0" Content="Date Facture:" Margin="5"/>

        <!-- Inputs -->
        <ComboBox x:Name="ClientComboBox" Grid.Row="0" Grid.Column="1" Margin="5" DisplayMemberPath="FullName" SelectedValuePath="IdCli"/>
        <DatePicker x:Name="DateFacturePicker" Margin="5,5,5,5" Grid.Column="1" Grid.Row="1"/>

        <!-- Boutons -->
        <StackPanel Grid.Row="2" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Left" Margin="100,10,0,0">
            <Button Content="Annuler" Width="100" Margin="0,0,10,0" Click="BtnAnnuler_Click"/>
            <Button Content="Créer Facture" Width="100" Background="#2196F3" Foreground="White" Click="BtnValider_Click"/>
        </StackPanel>
    </Grid>
</Window>
