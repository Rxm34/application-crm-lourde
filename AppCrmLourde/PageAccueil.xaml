<Page x:Class="AppCrmLourde.PageAccueil"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Accueil - AppCrmLourde"
      Width="1280" Height="720"
      Background="White">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Titre -->
            <RowDefinition Height="400"/>
            <!-- Agenda fixe -->
            <RowDefinition Height="Auto"/>
            <!-- Boutons -->
        </Grid.RowDefinitions>

        <!-- Titre -->
        <TextBlock Grid.Row="0" Text="{Binding TodayText}" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,10"/>

        <!-- Agenda scrollable -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <Grid x:Name="AgendaGrid" Margin="0,0,0,20"/>
        </ScrollViewer>

        <!-- Boutons -->
        <UniformGrid Grid.Row="2" Rows="1" Columns="5" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,10,0,0" Width="928" Height="100" >
            <Button Content="Prospects/Clients" FontSize="16" Margin="10,0"
            Background="#2C3E50" Foreground="White" FontWeight="SemiBold"
            Padding="10,5" BorderThickness="0" Cursor="Hand" Click="BtnPage1_Click">
                <Button.Effect>
                    <DropShadowEffect Color="Black" BlurRadius="5" ShadowDepth="2" Opacity="0.3"/>
                </Button.Effect>
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                      RecognizesAccessKey="True"/>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <Button Content="Rendez-vous" FontSize="16" Margin="10,0"
            Background="#2C3E50" Foreground="White" FontWeight="SemiBold"
            Padding="10,5" BorderThickness="0" Cursor="Hand" Click="BtnPage2_Click">
                <Button.Effect>
                    <DropShadowEffect Color="Black" BlurRadius="5" ShadowDepth="2" Opacity="0.3"/>
                </Button.Effect>
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                      RecognizesAccessKey="True"/>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <Button Content="Produits" FontSize="16" Margin="10,0"
            Background="#2C3E50" Foreground="White" FontWeight="SemiBold"
            Padding="10,5" BorderThickness="0" Cursor="Hand" Click="BtnPage3_Click">
                <Button.Effect>
                    <DropShadowEffect Color="Black" BlurRadius="5" ShadowDepth="2" Opacity="0.3"/>
                </Button.Effect>
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                      RecognizesAccessKey="True"/>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <Button Content="Factures" FontSize="16" Margin="10,0"
            Background="#2C3E50" Foreground="White" FontWeight="SemiBold"
            Padding="10,5" BorderThickness="0" Cursor="Hand" Click="BtnPage4_Click">
                <Button.Effect>
                    <DropShadowEffect Color="Black" BlurRadius="5" ShadowDepth="2" Opacity="0.3"/>
                </Button.Effect>
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                      RecognizesAccessKey="True"/>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <Button Content="Dashboard" FontSize="16" Margin="10,0"
            Background="#2C3E50" Foreground="White" FontWeight="SemiBold"
            Padding="10,5" BorderThickness="0" Cursor="Hand" Click="BtnPage5_Click">
                <Button.Effect>
                    <DropShadowEffect Color="Black" BlurRadius="5" ShadowDepth="2" Opacity="0.3"/>
                </Button.Effect>
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                          RecognizesAccessKey="True"/>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </UniformGrid>

    </Grid>
</Page>
