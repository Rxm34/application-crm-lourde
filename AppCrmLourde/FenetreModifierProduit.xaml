<Window x:Class="AppCrmLourde.FenetreModifierProduit"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Modifier un produit" Height="220" Width="400"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Nom :" Grid.Row="0" VerticalAlignment="Center"/>
        <TextBox x:Name="NomTextBox" Grid.Row="0" Margin="100,0,0,5"/>

        <TextBlock Text="Description :" Grid.Row="1" VerticalAlignment="Center"/>
        <TextBox x:Name="DescriptionTextBox" Grid.Row="1" Margin="100,0,0,5"/>

        <TextBlock Text="Prix :" Grid.Row="2" VerticalAlignment="Center"/>
        <TextBox x:Name="PrixTextBox" Grid.Row="2" Margin="100,0,0,5"/>

        <TextBlock Text="Stock :" Grid.Row="3" VerticalAlignment="Center"/>
        <TextBox x:Name="StockTextBox" Grid.Row="3" Margin="100,0,0,5"/>

        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,10">
            <Button Content="Annuler" Width="80" Margin="0,0,10,0" Click="Annuler_Click"/>
            <Button Content="Modifier" Width="80" Click="Valider_Click" Background="#2196F3" Foreground="White"/>
        </StackPanel>
    </Grid>
</Window>