<Page x:Class="AppCrmLourde.PageAdmin"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Administration" Height="720" Width="1280">

    <Grid Background="#F5F5F5">
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
            <TextBlock Text="PANNEAU D'ADMINISTRATION" FontSize="32" FontWeight="Bold" Foreground="#333" Margin="0,0,0,40" HorizontalAlignment="Center"/>

            <UniformGrid Columns="1" Width="500">

                <Button Margin="20" Height="150" Background="White" Click="BtnGestionManagers_Click">
                    <StackPanel>
                        <TextBlock Text="🔑" FontSize="40" HorizontalAlignment="Center"/>
                        <TextBlock Text="Accès Managers" FontSize="18" FontWeight="Bold" Margin="0,10,0,0"/>
                    </StackPanel>
                </Button>
            </UniformGrid>

            <Button Content="Retour" Width="150" Height="40" Margin="0,50,0,0" Background="#9E9E9E" Foreground="White" Click="BtnRetour_Click"/>
        </StackPanel>
    </Grid>
</Page>