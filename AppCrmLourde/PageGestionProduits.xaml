<Page x:Class="AppCrmLourde.PageGestionProduits"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Gestion des Produits" Height="720" Width="1280">

    <Grid Margin="20" Background="White">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="GESTION DU CATALOGUE PRODUITS" FontSize="26" FontWeight="Bold" Margin="0,0,0,20" Foreground="#2C3E50"/>

        <DataGrid x:Name="ProduitsDataGrid" Grid.Row="1" AutoGenerateColumns="False" 
                  CanUserAddRows="False" SelectionChanged="ProduitsDataGrid_SelectionChanged"
                  Margin="0,0,0,20" BorderThickness="1" BorderBrush="#DDD">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding IdProd}" Width="50"/>
                <DataGridTextColumn Header="Désignation" Binding="{Binding NomProd}" Width="2*"/>
                <DataGridTextColumn Header="Description" Binding="{Binding DescProd}" Width="3*"/>
                <DataGridTextColumn Header="Prix Unitaire" Binding="{Binding PrixProd, StringFormat={}{0:N2} €}" Width="*"/>
                <DataGridTextColumn Header="Stock" Binding="{Binding StockProd}" Width="80"/>
            </DataGrid.Columns>
        </DataGrid>

        <Border Grid.Row="2" Padding="15" Background="#F9F9F9" CornerRadius="8" BorderBrush="#EEE" BorderThickness="1">
            <StackPanel>
                <UniformGrid Columns="4" Margin="0,0,0,15">
                    <StackPanel Margin="5">
                        <TextBlock Text="Nom du produit :"/>
                        <TextBox x:Name="txtNom" Height="30" VerticalContentAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Margin="5">
                        <TextBlock Text="Prix (€) :"/>
                        <TextBox x:Name="txtPrix" Height="30" VerticalContentAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Margin="5">
                        <TextBlock Text="Stock initial :"/>
                        <TextBox x:Name="txtStock" Height="30" VerticalContentAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Margin="5">
                        <TextBlock Text="Description :"/>
                        <TextBox x:Name="txtDesc" Height="30" VerticalContentAlignment="Center"/>
                    </StackPanel>
                </UniformGrid>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Retour" Width="100" Height="35" Margin="5" Click="BtnRetour_Click" Background="#9E9E9E" Foreground="White"/>
                    <Button Content="🗑️ Supprimer" Width="120" Height="35" Margin="5" Click="BtnSupprimer_Click" Background="#F44336" Foreground="White"/>
                    <Button x:Name="btnEnregistrer" Content="💾 Enregistrer" Width="150" Height="35" Margin="5" Click="BtnEnregistrer_Click" Background="#4CAF50" Foreground="White" FontWeight="Bold"/>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</Page>