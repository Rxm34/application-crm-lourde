<Window x:Class="AppCrmLourde.FenetreAjouterProduit"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Ajouter un produit" Height="230" Width="400"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Nom -->
        <TextBlock Text="Nom :" Grid.Row="0" VerticalAlignment="Center"/>
        <TextBox x:Name="NomTextBox" Grid.Row="0" Margin="100,0,0,5"/>

        <!-- Description -->
        <TextBlock Text="Description :" Grid.Row="1" VerticalAlignment="Center"/>
        <TextBox x:Name="DescriptionTextBox" Grid.Row="1" Margin="100,0,0,5"/>

        <!-- Prix -->
        <TextBlock Text="Prix :" Grid.Row="2" VerticalAlignment="Center"/>
        <TextBox x:Name="PrixTextBox" Grid.Row="2" Margin="100,0,0,5"/>

        <!-- Stock -->
        <TextBlock Text="Stock :" Grid.Row="3" VerticalAlignment="Center"/>
        <TextBox x:Name="StockTextBox" Grid.Row="3" Margin="100,0,0,5"/>

        <!-- Boutons -->
        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Left" Margin="100,10,0,10">
            <Button Content="Annuler" Width="100" Margin="0,10,10,0" Click="BtnAnnuler_Click"/>
            <Button Content="Valider" Width="100" Margin="0,10,0,0" Background="#2196F3" Foreground="White" Click="BtnValider_Click"/>
        </StackPanel>
    </Grid>
</Window>