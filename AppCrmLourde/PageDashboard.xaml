<Page x:Class="AppCrmLourde.PageDashboard"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:lvc="clr-namespace:LiveCharts.Wpf;assembly=LiveCharts.Wpf"
      mc:Ignorable="d" 
      d:DesignHeight="720" d:DesignWidth="1280"
      Title="PageDashboard"
      Background="White">

    <Grid Margin="0">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Header -->
            <RowDefinition Height="Auto"/>
            <!-- Indicateurs -->
            <RowDefinition Height="*"/>
            <!-- Graphique CA -->
            <RowDefinition Height="*"/>
            <!-- Graphique RDV -->
            <RowDefinition Height="Auto"/>
            <!-- Export PDF -->
        </Grid.RowDefinitions>

        <!-- ===== HEADER ===== -->
        <DockPanel Grid.Row="0" Margin="20">
            <TextBlock Text="Tableau de bord"
                       FontSize="28"
                       FontWeight="Bold"
                       Foreground="#2C3E50"
                       HorizontalAlignment="Center"/>
            <Button Content="← Retour" Width="100" Height="35"
                    Background="#9E9E9E" Foreground="White" FontWeight="Bold"
                    HorizontalAlignment="Right"
                    Click="BtnRetour_Click"/>
        </DockPanel>

        <!-- ===== INDICATEURS ===== -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="20,0,20,30">
            <StackPanel Margin="10">
                <Border Background="#3498DB" CornerRadius="12" Padding="20" Width="180">
                    <StackPanel>
                        <TextBlock Text="CA du Mois" Foreground="White" FontSize="16"/>
                        <TextBlock x:Name="lblCaMois" Foreground="White" FontSize="22" FontWeight="Bold"/>
                    </StackPanel>
                </Border>
            </StackPanel>

            <StackPanel Margin="10">
                <Border Background="#27AE60" CornerRadius="12" Padding="20" Width="180">
                    <StackPanel>
                        <TextBlock Text="RDV ce Mois" Foreground="White" FontSize="16"/>
                        <TextBlock x:Name="lblRdvMois" Foreground="White" FontSize="22" FontWeight="Bold"/>
                    </StackPanel>
                </Border>
            </StackPanel>

            <StackPanel Margin="10">
                <Border Background="#F39C12" CornerRadius="12" Padding="20" Width="180">
                    <StackPanel>
                        <TextBlock Text="Produits Vendus" Foreground="White" FontSize="16"/>
                        <TextBlock x:Name="lblProduitsVendus" Foreground="White" FontSize="22" FontWeight="Bold"/>
                    </StackPanel>
                </Border>
            </StackPanel>

            <StackPanel Margin="10">
                <Border Background="#8E44AD" CornerRadius="12" Padding="20" Width="180">
                    <StackPanel>
                        <TextBlock Text="Top Client" Foreground="White" FontSize="16"/>
                        <TextBlock x:Name="lblTopClient" Foreground="White" FontSize="22" FontWeight="Bold"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </StackPanel>

        <!-- ===== GRAPHIQUE CA / MOIS ===== -->
        <GroupBox Grid.Row="2" Header="Chiffre d'affaires par mois" FontWeight="Bold" Margin="20">
            <lvc:CartesianChart x:Name="chartCaParMois"/>
        </GroupBox>

        <!-- ===== GRAPHIQUE RDV / MOIS ===== -->
        <GroupBox Grid.Row="3" Header="Nombre de RDV par mois" FontWeight="Bold" Margin="20">
            <lvc:CartesianChart x:Name="chartRdv"/>
        </GroupBox>

        <!-- ===== BOUTON EXPORT PDF ===== -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="20,10,20,20">
            <Button Content="📄 Export PDF" Width="120" Height="35"
                    Background="#2196F3" Foreground="White" FontWeight="Bold"
                    Click="BtnExportPdf_Click"/>
        </StackPanel>

    </Grid>
</Page>
