<Window x:Class="AppCrmLourde.FenetreModifierFacture"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Modifier Facture" Height="320" Width="400"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="120"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Labels -->
        <Label Grid.Row="0" Grid.Column="0" Content="Client:" Margin="5"/>
        <Label Grid.Row="1" Grid.Column="0" Content="Produit:" Margin="5"/>
        <Label Grid.Row="2" Grid.Column="0" Content="Quantité:" Margin="5"/>
        <Label Grid.Row="3" Grid.Column="0" Content="Prix Produit:" Margin="5"/>
        <Label Grid.Row="4" Grid.Column="0" Content="Prix Facture:" Margin="5"/>
        <Label Grid.Row="5" Grid.Column="0" Content="Date Facture:" Margin="5"/>

        <!-- Champs -->
        <ComboBox x:Name="ClientComboBox" Grid.Row="0" Grid.Column="1" Margin="5"/>
        <ComboBox x:Name="ProduitComboBox" Grid.Row="1" Grid.Column="1" Margin="5"/>
        <TextBox x:Name="QteTextBox" Grid.Row="2" Grid.Column="1" Margin="5"/>
        <TextBox x:Name="PrixProdTextBox" Grid.Row="3" Grid.Column="1" Margin="5"/>
        <TextBox x:Name="PrixFactTextBox" Grid.Row="4" Grid.Column="1" Margin="5"/>
        <DatePicker x:Name="DateFacturePicker" Grid.Row="5" Grid.Column="1" Margin="5"/>

        <!-- Boutons -->
        <StackPanel Grid.Row="6" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Left" Margin="100,5,0,5">
            <Button Content="Annuler" Width="100" Margin="0,10,10,0" Click="BtnAnnuler_Click"/>
            <Button Content="Valider" Width="100" Margin="0,10,0,0" Background="#2196F3" Foreground="White" Click="BtnValider_Click"/>
        </StackPanel>
    </Grid>
</Window>
