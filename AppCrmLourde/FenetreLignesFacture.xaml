<Window x:Class="AppCrmLourde.FenetreLignesFacture"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Lignes de Facture" Height="500" Width="800"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="TxtInfoFacture" Grid.Row="0" FontSize="16" FontWeight="Bold" Margin="0,0,0,10" />

        <DataGrid x:Name="LignesDataGrid" Grid.Row="1" AutoGenerateColumns="False" CanUserAddRows="False" Margin="0,0,0,10">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Produit" Binding="{Binding NomProduit}" Width="*" />
                <DataGridTextColumn Header="Quantité" Binding="{Binding QteProd}" Width="*" />
                <DataGridTextColumn Header="Prix Unitaire" Binding="{Binding PrixProd, StringFormat=C2}" Width="*" />
                <DataGridTextColumn Header="Total Ligne" Binding="{Binding PrixTotalLigne, StringFormat=C2}" Width="*" />
            </DataGrid.Columns>
        </DataGrid>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock x:Name="TxtTotalFacture" Grid.Column="0" FontSize="16" FontWeight="Bold" VerticalAlignment="Center" />

            <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="➕ Ajouter" Width="100" Height="30" Margin="10,0,0,0" Background="#4CAF50" Foreground="White" FontWeight="Bold" Click="BtnAjouter_Click" />
                <Button Content="✏️ Modifier" Width="100" Height="30" Margin="10,0,0,0" Background="#2196F3" Foreground="White" FontWeight="Bold" Click="BtnModifier_Click" />
                <Button Content="🗑️ Supprimer" Width="100" Height="30" Margin="10,0,0,0" Background="#F44336" Foreground="White" FontWeight="Bold" Click="BtnSupprimer_Click" />
                <Button Content="Valider" Width="100" Height="30" Margin="10,0,0,0" Background="#607D8B" Foreground="White" FontWeight="Bold" Click="BtnValider_Click" />
            </StackPanel>
        </Grid>
    </Grid>
</Window>