<Window x:Class="AppCrmLourde.FenetreLignesFacture"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Détails des articles" Height="450" Width="600" WindowStartupLocation="CenterScreen">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <GroupBox Header="Ajouter un article" Grid.Row="0" Margin="0,0,0,10">
            <StackPanel Orientation="Horizontal" Margin="5">
                <ComboBox x:Name="ProduitComboBox" Width="200" DisplayMemberPath="NomProd" Margin="5"/>
                <TextBox x:Name="QteTextBox" Width="50" Margin="5" VerticalContentAlignment="Center" Text="1"/>
                <Button Content="Ajouter" Width="80" Margin="5" Click="BtnAjouterLigne_Click" Background="#4CAF50" Foreground="White"/>
            </StackPanel>
        </GroupBox>

        <DataGrid x:Name="LignesDataGrid" Grid.Row="1" AutoGenerateColumns="False" CanUserAddRows="False">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Produit" Binding="{Binding NomProduit}" Width="2*"/>
                <DataGridTextColumn Header="Prix Unitaire" Binding="{Binding PUProd, StringFormat={}{0:C2}}" Width="*"/>
                <DataGridTextColumn Header="Qté" Binding="{Binding Qte}" Width="50"/>
                <DataGridTemplateColumn Width="80">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="Supprimer" Click="BtnSupprimerLigne_Click" Background="#F44336" Foreground="White"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <Button Content="Fermer et Enregistrer" Grid.Row="2" Width="150" HorizontalAlignment="Right" Margin="0,10,0,0" Click="BtnFermer_Click"/>
    </Grid>
</Window>