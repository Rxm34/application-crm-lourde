<Page x:Class="AppCrmLourde.PageInscription"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Inscription - AppCrmLourde"
      Width="1280" Height="720"
      Background="White">

    <Grid>
        <Border Width="512" MinWidth="400" MaxWidth="600"
                HorizontalAlignment="Center" VerticalAlignment="Center"
                Padding="30"
                Background="#F0F0F0"
                CornerRadius="10"
                BorderBrush="#CCCCCC"
                BorderThickness="1">
            <StackPanel>
                <TextBlock Text="Inscription" FontSize="28" FontWeight="Bold" Margin="0,0,0,30" TextAlignment="Center"/>

                <TextBlock Text="Nom :" FontSize="16"/>
                <TextBox x:Name="txtNom" Margin="0,5,0,15" FontSize="16"/>

                <TextBlock Text="Prénom :" FontSize="16"/>
                <TextBox x:Name="txtPrenom" Margin="0,5,0,15" FontSize="16"/>

                <TextBlock Text="Adresse Email :" FontSize="16"/>
                <TextBox x:Name="txtEmail" Margin="0,5,0,15" FontSize="16"/>

                <TextBlock Text="Mot de passe :" FontSize="16"/>
                <PasswordBox x:Name="txtMotDePasse" Margin="0,5,0,15" FontSize="16"/>

                <TextBlock Text="Confirmer le mot de passe :" FontSize="16"/>
                <PasswordBox x:Name="txtMotDePasseConfirm" Margin="0,5,0,20" FontSize="16"/>

                <CheckBox x:Name="chkIsAdmin" Content="S'inscrire en tant qu'administrateur" 
                          FontSize="14" Margin="0,0,0,20" Cursor="Hand" VerticalContentAlignment="Center"/>

                <Button x:Name="btnInscription" Content="S'inscrire" Height="40" FontSize="16" 
                        Background="#2196F3" Foreground="White" FontWeight="Bold" Click="btnInscription_Click">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="5"/>
                        </Style>
                    </Button.Resources>
                </Button>

                <TextBlock HorizontalAlignment="Center" Margin="0,30,0,0" FontSize="14" TextAlignment="Center">
                    <Run Text="Déjà un compte ? "/>
                    <Hyperlink Click="Hyperlink_Connexion_Click" Cursor="Hand">Se connecter</Hyperlink>
                </TextBlock>

                <TextBlock x:Name="lblMessage" Foreground="Red" Margin="0,10,0,0" TextAlignment="Center" FontSize="14"/>
            </StackPanel>
        </Border>
    </Grid>
</Page>