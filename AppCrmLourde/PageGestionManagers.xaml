<Page x:Class="AppCrmLourde.PageGestionManagers"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Gestion des Managers" Height="720" Width="1280">

    <Grid Margin="20" Background="White">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="GESTION DES COMPTES MANAGERS" FontSize="26" FontWeight="Bold" Margin="0,0,0,20" Foreground="#2C3E50"/>

        <DataGrid x:Name="ManagersDataGrid" Grid.Row="1" AutoGenerateColumns="False" 
                  CanUserAddRows="False" SelectionChanged="ManagersDataGrid_SelectionChanged"
                  Margin="0,0,0,20" BorderThickness="1" BorderBrush="#DDD" IsReadOnly="True">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding IdMan}" Width="50"/>
                <DataGridTextColumn Header="Nom" Binding="{Binding NomMan}" Width="*"/>
                <DataGridTextColumn Header="Prénom" Binding="{Binding PrenomMan}" Width="*"/>
                <DataGridTextColumn Header="Email" Binding="{Binding MailMan}" Width="2*"/>
                <DataGridCheckBoxColumn Header="Est Admin" Binding="{Binding IsAdmin}" Width="100"/>
            </DataGrid.Columns>
        </DataGrid>

        <Border Grid.Row="2" Padding="15" Background="#F9F9F9" CornerRadius="8" BorderBrush="#EEE" BorderThickness="1">
            <StackPanel>
                <UniformGrid Columns="3" Margin="0,0,0,10">
                    <StackPanel Margin="5">
                        <TextBlock Text="Nom :"/>
                        <TextBox x:Name="txtNom" Height="30"/>
                    </StackPanel>
                    <StackPanel Margin="5">
                        <TextBlock Text="Prénom :"/>
                        <TextBox x:Name="txtPrenom" Height="30"/>
                    </StackPanel>
                    <StackPanel Margin="5">
                        <TextBlock Text="Email :"/>
                        <TextBox x:Name="txtEmail" Height="30"/>
                    </StackPanel>

                    <StackPanel Margin="5">
                        <TextBlock Text="Nouveau Mot de passe :"/>
                        <PasswordBox x:Name="txtMdp" Height="30"/>
                    </StackPanel>

                    <CheckBox x:Name="chkIsAdmin" Content="Droits Administrateur" VerticalAlignment="Center" Margin="5,20,0,0" FontSize="14"/>
                </UniformGrid>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Retour" Width="100" Height="35" Margin="5" Click="BtnRetour_Click" Background="#9E9E9E" Foreground="White"/>
                    <Button Content="🗑️ Supprimer" Width="120" Height="35" Margin="5" Click="BtnSupprimer_Click" Background="#F44336" Foreground="White"/>
                    <Button x:Name="btnEnregistrer" Content="💾 Enregistrer" Width="180" Height="35" Margin="5" Click="BtnEnregistrer_Click" Background="#4CAF50" Foreground="White" FontWeight="Bold"/>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</Page>