<Window x:Class="AppCrmLourde.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Connexion - AppCrmLourde"
        Height="720" Width="1280"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">
    <Grid>

        <!-- Formulaire de connexion -->
        <Border x:Name="ConnexionBorder"
                Width="512" MinWidth="400" MaxWidth="600"
                HorizontalAlignment="Center" VerticalAlignment="Center"
                Padding="30"
                Background="#F0F0F0"
                CornerRadius="10"
                BorderBrush="#CCCCCC"
                BorderThickness="1">
            <StackPanel>
                <TextBlock Text="Connexion" FontSize="28" FontWeight="Bold" Margin="0,0,0,30" TextAlignment="Center"/>
                <TextBlock Text="Adresse Email:" FontSize="16"/>
                <TextBox x:Name="txtEmail" Margin="0,5,0,20" FontSize="16"/>
                <TextBlock Text="Mot de passe:" FontSize="16"/>
                <PasswordBox x:Name="txtMotDePasse" Margin="0,5,0,20" FontSize="16"/>
                <Button x:Name="btnConnexion" Content="Se connecter" Height="40" FontSize="16" Click="btnConnexion_Click"/>
                <TextBlock HorizontalAlignment="Center" Margin="0,30,0,0" FontSize="14" TextAlignment="Center">
                    <Run Text="Pas encore de compte ? "/>
                    <Hyperlink Click="Hyperlink_Sinscrire_Click" Cursor="Hand">S'inscrire</Hyperlink>
                </TextBlock>
                <TextBlock x:Name="lblMessage" Foreground="Red" Margin="0,10,0,0" TextAlignment="Center" FontSize="14"/>
            </StackPanel>
        </Border>

        <!-- Frame pour afficher la page d'inscription -->
        <Frame x:Name="MainFrame" NavigationUIVisibility="Hidden"/>

    </Grid>
</Window>
