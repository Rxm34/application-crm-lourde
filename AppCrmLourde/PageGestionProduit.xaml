<Page x:Class="AppCrmLourde.PageGestionProduit"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:AppCrmLourde"
      mc:Ignorable="d" 
      Height="720" Width="1280"
      Title="PageGestionProduit">

    <Grid Margin="20" Background="White">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- barre (retour + recherche) -->
            <RowDefinition Height="550"/>
            <!-- DataGrid (prend l'espace restant) -->
            <RowDefinition Height="60"/>
            <!-- boutons -->
        </Grid.RowDefinitions>

        <!-- BARRE HAUTE : BOUTON RETOUR + RECHERCHE -->
        <DockPanel Grid.Row="0" Margin="0,0,0,10">
            <!-- BOUTON RETOUR EN HAUT À GAUCHE -->
            <Button Content="← Retour" Width="100" Height="35" Margin="0,0,10,0"
                    Background="#9E9E9E" Foreground="White" FontWeight="Bold"
                    DockPanel.Dock="Left"
                    Click="BtnRetour_Click"/>

            <!-- RECHERCHE À DROITE -->
            <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" HorizontalAlignment="Right">
                <TextBox x:Name="txtSearch" Width="250" Height="35" Margin="0,0,10,0"
                         Padding="10,0" VerticalContentAlignment="Center"
                         FontSize="14"/>
                <Button Content="🔍 Rechercher" Width="130" Height="35"
                        Background="#607D8B" Foreground="White"
                        FontWeight="Bold" Click="BtnSearch_Click"/>
            </StackPanel>
        </DockPanel>

        <!-- Tableau Produits -->
        <DataGrid x:Name="ProduitsDataGrid"
                  Grid.Row="1"
                  ItemsSource="{Binding Produits}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  Margin="0,0,0,10">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Nom" Binding="{Binding NomProd}" Width="*" />
                <DataGridTextColumn Header="Description" Binding="{Binding DescProd}" Width="2*" />
                <DataGridTextColumn Header="Prix" Binding="{Binding PrixProd}" Width="100" />
                <DataGridTextColumn Header="Stock" Binding="{Binding StockProd}" Width="100" />
            </DataGrid.Columns>
        </DataGrid>

        <!-- BOUTONS -->
        <Grid Grid.Row="2" Margin="0,5,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Orientation="Horizontal" Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center">
                <Button Content="➕ Ajouter" Width="120" Height="35" Margin="10,0,0,0"
                        Background="#4CAF50" Foreground="White" FontWeight="Bold"
                        Click="BtnAjouter_Click"/>
                <Button Content="✏️ Modifier" Width="120" Height="35" Margin="10,0,0,0"
                        Background="#2196F3" Foreground="White" FontWeight="Bold"
                        Click="BtnModifier_Click"/>
                <Button Content="🗑️ Supprimer" Width="120" Height="35" Margin="10,0,0,0"
                        Background="#F44336" Foreground="White" FontWeight="Bold"
                        Click="BtnSupprimer_Click"/>
            </StackPanel>
        </Grid>
    </Grid>
</Page>
