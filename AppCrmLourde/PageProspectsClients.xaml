<Page x:Class="AppCrmLourde.PageProspectsClients"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Prospects_Clients - AppCrmLourde"
      Width="1280" Height="720"
      Background="#f9fafc">

    <Grid Margin="20" Background="White">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Barre de recherche + bouton retour -->
            <RowDefinition Height="550"/>
            <!-- DataGrid -->
            <RowDefinition Height="60"/>
            <!-- Filtre + boutons -->
        </Grid.RowDefinitions>

        <!-- BARRE HAUTE : BOUTON RETOUR + RECHERCHE -->
        <DockPanel Grid.Row="0" Margin="0,0,0,10">
            <!-- BOUTON RETOUR EN HAUT À GAUCHE -->
            <Button Content="← Retour" Width="100" Height="35" Margin="0,0,10,0"
                    Background="#9E9E9E" Foreground="White" FontWeight="Bold"
                    DockPanel.Dock="Left"
                    Click="BtnRetour_Click"/>

            <!-- RECHERCHE À DROITE -->
            <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" HorizontalAlignment="Right">
                <TextBox x:Name="txtSearch" Width="250" Height="35" Margin="0,0,10,0"
                         Padding="10,0" VerticalContentAlignment="Center"
                         FontSize="14"/>
                <Button Content="🔍 Rechercher" Width="130" Height="35"
                        Background="#607D8B" Foreground="White"
                        FontWeight="Bold" Click="BtnSearch_Click"/>
            </StackPanel>
        </DockPanel>

        <!-- DATAGRID COLLÉ SOUS LA BARRE HAUTE -->
        <Border Grid.Row="1" BorderBrush="#dcdcdc" BorderThickness="1" CornerRadius="5" Padding="5">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <DataGrid x:Name="dgClientsProspects"
          AutoGenerateColumns="False"
          CanUserAddRows="False"
          CanUserDeleteRows="False"
          SelectionMode="Single"
          AlternatingRowBackground="#f7f9fc"
          RowHeight="30"
          FontSize="13"
          BorderBrush="#e0e0e0"
          BorderThickness="1"
          HeadersVisibility="Column">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Type" Binding="{Binding Type}" Width="*" />
                        <DataGridTextColumn Header="Nom" Binding="{Binding Nom}" Width="*" />
                        <DataGridTextColumn Header="Prénom" Binding="{Binding Prenom}" Width="*" />
                        <DataGridTextColumn Header="Mail" Binding="{Binding Mail}" Width="2*" />
                        <DataGridTextColumn Header="Téléphone" Binding="{Binding Telephone}" Width="*" />
                        <DataGridTextColumn Header="Ville" Binding="{Binding Ville}" Width="*" />
                        <DataGridTextColumn Header="Code Postal" Binding="{Binding CodePostal}" Width="*" />
                        <DataGridTextColumn Header="Rue" Binding="{Binding Rue}" Width="2*" />
                    </DataGrid.Columns>
                </DataGrid>
            </ScrollViewer>
        </Border>

        <!-- FILTRE + BOUTONS SOUS LE DATAGRID -->
        <Grid Grid.Row="2" Margin="0,5,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- FILTRE CENTRÉ VERTICALEMENT -->
            <StackPanel Orientation="Horizontal" Grid.Column="0" VerticalAlignment="Center">
                <TextBlock Text="Filtrer par type :" VerticalAlignment="Center" Margin="0,0,10,0" FontWeight="Bold"/>
                <ComboBox x:Name="cbType" Width="150" Height="30" SelectedIndex="0">
                    <ComboBoxItem Content="Tous"/>
                    <ComboBoxItem Content="Client"/>
                    <ComboBoxItem Content="Prospect"/>
                </ComboBox>
                <Button Content="Appliquer" Width="100" Height="30" Margin="10,0,0,0"
                        Background="#607D8B" Foreground="White" FontWeight="Bold"
                        Click="BtnFilter_Click"/>
            </StackPanel>

            <!-- BOUTONS À DROITE -->
            <StackPanel Orientation="Horizontal" Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center">
                <Button Content="➕ Ajouter" Width="120" Height="35" Margin="10,0,0,0"
                        Background="#4CAF50" Foreground="White" FontWeight="Bold"
                        Click="BtnAjouter_Click"/>
                <Button Content="✏️ Modifier" Width="120" Height="35" Margin="10,0,0,0"
                        Background="#2196F3" Foreground="White" FontWeight="Bold"
                        Click="BtnModifier_Click"/>
                <Button Content="🗑️ Supprimer" Width="120" Height="35" Margin="10,0,0,0"
                        Background="#F44336" Foreground="White" FontWeight="Bold"
                        Click="BtnSupprimer_Click"/>
            </StackPanel>
        </Grid>
    </Grid>
</Page>
